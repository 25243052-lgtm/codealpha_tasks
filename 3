#include <stdio.h>
#include <stdlib.h>

struct student {
    int id;
    char name[50];
    float marks;
};

void add() {
    FILE *fp = fopen("students.txt", "a");
    struct student s;

    printf("Enter ID Name Marks: ");
    scanf("%d %s %f", &s.id, s.name, &s.marks);

    fwrite(&s, sizeof(s), 1, fp);
    fclose(fp);
}

void display() {
    FILE *fp = fopen("students.txt", "r");
    struct student s;

    while(fread(&s, sizeof(s), 1, fp))
        printf("%d %s %.2f\n", s.id, s.name, s.marks);

    fclose(fp);
}

int main() {
    int choice;

    while(1) {
        printf("\n1.Add\n2.Display\n3.Exit\n");
        scanf("%d", &choice);

        switch(choice) {
            case 1: add(); break;
            case 2: display(); break;
            case 3: exit(0);
        }
    }
}
